{
  "expo": {
    "name": "引越し日和",
    "slug": "moving-checklist",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFAF9"
    },
    "ios": {
      "bundleIdentifier": "com.tama.movingchecklist",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "NSCalendarsUsageDescription": "Moving Checklist uses your calendar to schedule task reminders."
      }
    },
    "android": {
      "package": "com.tama.movingchecklist",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFAF9"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-notifications",
      "expo-localization",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Moving Checklist to access your photos to attach them to tasks.",
          "cameraPermission": "Allow Moving Checklist to use the camera to take photos for tasks."
        }
      ]
    ]
  }
}
